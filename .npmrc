# npm config reference:
# https://docs.npmjs.com/cli/v11/using-npm/config

# npm best practises:
# https://github.com/bodadotsh/npm-security-best-practices

# Enforce deterministic installs when adding deps
save-exact=true

# Block lifecycle scripts (common attack vector)
ignore-scripts=true

# Delay installing newly published packages (days)
min-release-age=5

# Enable provenance (supply-chain integrity)
provenance=true

# Stricter dependency validation
strict-peer-deps=true
